    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "jose": "^6.2.3",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "openai": "^6.46.0",
    "pg": "^8.20.0",
    "undici": "^7.25.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "prisma": "^7.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
