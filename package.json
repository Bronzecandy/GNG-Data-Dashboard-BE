{
  "name": "data-dashboard-be",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run prisma:generate && tsc",
    "start": "node dist/src/index.js",
    "postinstall": "npm run prisma:generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "setup:db:windows": "powershell -ExecutionPolicy Bypass -File scripts/setup-db-windows.ps1",
    "seed:auth": "tsx src/scripts/seed-auth.ts",
    "ingest:backfill": "tsx src/scripts/ingest-cli.ts backfill",
    "ingest:qa": "tsx src/scripts/ingest-qa.ts",
    "ingest:reset": "tsx src/scripts/ingest-reset.ts",
    "ingest:daily": "tsx src/scripts/ingest-cli.ts daily",
    "ingest:gaps": "tsx src/scripts/backfill-missing-days.ts",
    "verify:tabs": "tsx src/scripts/verify-tabs.ts",
    "sync:seed": "node scripts/sync-seed-from-fe.mjs",
    "bean:smoke": "tsx src/scripts/bean-smoke.ts",
    "bean:explore": "tsx src/scripts/bean-explore.ts",
    "bean:discover": "tsx src/scripts/bean-discover.ts",
    "bean:discover:bulk": "tsx src/scripts/bean-discover-bulk.ts",
    "bean:catalog:merge": "tsx src/scripts/bean-catalog-merge.ts",
