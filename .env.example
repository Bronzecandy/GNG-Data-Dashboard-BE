# Server
PORT=3001
NODE_ENV=development

# Postgres (PostgreSQL Windows â€” port 5432, khÃ´ng Docker)
# Cháº¡y: npm run setup:db:windows
DATABASE_URL=postgresql://dashboard:dashboard_dev@localhost:5432/dashboard_local

# Auth
AUTH_JWT_SECRET=change-me-to-a-long-random-string
AUTH_COOKIE_SECURE=false
AUTH_FRONTEND_URL=http://localhost:5173
AUTH_API_BASE_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:5173

# Demo LAN: skip Google login (set true with FE VITE_DISABLE_AUTH=true)
DISABLE_AUTH=false

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ADMIN_BOOTSTRAP_EMAIL=thanhnam.tranngoc@garena.vn

# Bean OpenAPI
BEAN_BASE_URL=https://bean.data.garenanow.com
BEAN_CLIENT_APP_ID=
BEAN_CLIENT_TOKEN=
BEAN_USER_EMAIL=
BEAN_CLUSTER_URN=platform:(hive,sg-cluster)

# Ingestion scope (server region + player IP region)
INGEST_REGION=SG
INGEST_IP_REGION=VN
HISTORY_START_DATE=2025-01-02
HISTORY_END_DATE=2026-07-03
# SQL-side aggregation returns ~1 row/query (Bean caps concurrency at 10 per user)
BEAN_MIN_INTERVAL_MS=2000
BEAN_INGEST_CONCURRENCY=4
BEAN_QUERY_DELAY_MS=1000
BEAN_DAY_RETRIES=5
BEAN_RESULT_RETRIES=4
BEAN_POST_SUCCESS_DELAY_MS=2000

# Optional: tab template JSON fallback (default: ./seed-data inside be/)
# FE_PUBLIC_DATA_DIR=./seed-data

# Socialdata GraphQL (internal social listening)
SOCIALDATA_BASE_URL=https://socialdata.garena.vn
# Google service-account JSON key (grant SA email on socialdata.garena.vn first)
SOCIALDATA_GOOGLE_CREDENTIALS=secrets/socialdata-sa.json
# Optional manual session (24h); skips SA exchange when set
# SOCIALDATA_USESSION=

# OpenAI / Compass (Hero Balance Create Report)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://compass.llm.shopee.io/compass-api/v1
OPENAI_MODEL=gpt-5.4

# Crawly Advanced APIs (community sentiment)
CRAWLY_BASE_URL=https://crawly-slt.ingarena.net
CRAWLY_TOKEN=
CRAWLY_GAME=GNG
CRAWLY_REGION=VN

# Ingest cron (default: every 2 hours Asia/Ho_Chi_Minh — today each run; +yesterday at 02:00 & 04:00)
# DISABLE_INGEST_CRON=true
# INGEST_TIMEZONE=Asia/Ho_Chi_Minh

# StarRocks MCP (gng-data-explorer skill — optional, for ad-hoc queries)
# STARROCKS_MCP_URL=https://sr-mcp.data.garenanow.com/mcp
# STARROCKS_MCP_TOKEN=
